---
import Base from '../layouts/Base.astro';

/** Bestand in public/ — wordt op de site-root geserveerd */
const cvPdfHref = '/CV_Marc_Halewyn_20260323.pdf';
---

<Base
  title="Agile Halewyn — Freelance Test Engineer & Testcoördinator"
  description="Marc Halewyn — freelance Test Engineer & Testcoördinator gespecialiseerd in testautomatisering en kwaliteitsborging binnen overheid, zorg en energie."
>

  <!-- Navigation -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="#" class="nav-logo">
        <span class="nav-logo-mark">AH</span>
        <span class="nav-logo-text">Agile Halewyn</span>
      </a>
      <div class="nav-links">
        <a href="#wat-ik-doe">Wat ik doe</a>
        <a href="#opdrachten">Opdrachten</a>
        <a href="#tools">Tools</a>
        <a href="#over-mij">Over mij</a>
        <a href="#contact" class="nav-cta">Contact</a>
      </div>
      <button class="nav-toggle" aria-label="Menu openen" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  <!-- Hero -->
  <header class="hero">
    <div class="hero-inner">
      <div class="hero-content">
        <p class="hero-label">Freelance ZZP — beschikbaar voor opdrachten</p>
        <h1>Marc Halewyn</h1>
        <p class="hero-title">Test Engineer & Testcoördinator</p>
        <p class="hero-sub">
          Testautomatisering en kwaliteitsborging binnen overheid, zorg en energie.
          Ik combineer strategische testcoördinatie met hands-on technische uitvoering.
        </p>
        <div class="hero-actions">
          <a href="#contact" class="btn btn-primary">Neem contact op</a>
          <a href="#wat-ik-doe" class="btn btn-outline">Bekijk wat ik doe</a>
        </div>
        <p class="hero-cv-note">
          <a href={cvPdfHref} target="_blank" rel="noopener">CV downloaden (PDF)</a>
        </p>
      </div>
    </div>
  </header>

  <!-- Wat ik doe -->
  <section id="wat-ik-doe" class="section">
    <div class="container">
      <h2 class="section-title">Wat ik doe</h2>
      <p class="section-intro">
        Wat mij onderscheidt is de combinatie van twee disciplines die zelden in één persoon samenkomen.
        Ik kan het testproces strategisch aansturen én zelf de frameworks bouwen.
      </p>
      <div class="two-col">
        <div class="card">
          <div class="card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H2v7l6.29 6.29c.94.94 2.48.94 3.42 0l4.58-4.58c.94-.94.94-2.48 0-3.42L9 5Z"/><path d="M6 9.01V9"/><path d="m15 5 6.3 6.3a2.4 2.4 0 0 1 0 3.4L17 19"/></svg>
          </div>
          <h3>Testcoördinatie</h3>
          <p>
            Master Test Plans, Requirements Traceability Matrices, release-acceptatieprocessen
            en risicoanalyse. Ik stuur testtrajecten aan, begeleid scrumteams richting Shift Left,
            en zorg voor aantoonbare kwaliteitsborging via traceerbaarheid van requirements.
          </p>
          <ul class="card-tags">
            <li>TMap Suite</li>
            <li>PSM I</li>
            <li>RTM</li>
            <li>Shift Left</li>
            <li>Risicoanalyse</li>
          </ul>
        </div>
        <div class="card">
          <div class="card-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/><line x1="12" y1="2" x2="12" y2="22" opacity="0.3"/></svg>
          </div>
          <h3>Testautomatisering</h3>
          <p>
            Frameworks opzetten van de grond af aan, integreren in CI/CD-pipelines en
            overdragen aan teams. Van front-end regressietesten met Cypress en Playwright
            tot back-end API-testing (REST &amp; SOAP) met Parasoft en Postman.
          </p>
          <ul class="card-tags">
            <li>Cypress</li>
            <li>Playwright</li>
            <li>Parasoft</li>
            <li>REST / SOAP</li>
            <li>CI/CD</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Opdrachten -->
  <section id="opdrachten" class="section section-alt">
    <div class="container">
      <h2 class="section-title">Recente opdrachten</h2>
      <p class="section-intro">
        Een selectie van opdrachten die mijn breedte illustreren, van nationaal zorgplatform
        tot overheidstoegankelijkheid en e-commerce testautomatisering.
      </p>

      <div class="timeline">
        <article class="timeline-item">
          <div class="timeline-meta">
            <span class="timeline-sector">Zorg</span>
            <span class="timeline-period">2023 – 2026</span>
          </div>
          <h3>VZVZ — Testcoördinator</h3>
          <p>
            Testcoördinatie binnen het AORTA on FHIR-project: de modernisering van de
            nationale zorginformatievoorziening naar de FHIR-standaard (HL7). Dit platform
            verwerkt dagelijks miljoenen berichten tussen zorgverleners.
          </p>
          <ul class="result-list">
            <li>RTM opgezet en gestructureerd voor het volledige AORTA on FHIR-testtraject</li>
            <li>SOAP- en REST-integratietesten met Parasoft op berichtniveau</li>
            <li>Testplannen, risicoanalyses en release-acceptatie aangestuurd</li>
          </ul>
        </article>

        <article class="timeline-item">
          <div class="timeline-meta">
            <span class="timeline-sector">Overheid</span>
            <span class="timeline-period">2021 – 2022</span>
          </div>
          <h3>DICTU / RVO — Test Automation Engineer</h3>
          <p>
            Kwaliteitsborging van Drupal-webapplicaties binnen de Rijksoverheid,
            met een sterke focus op digitale toegankelijkheid conform WCAG 2.1 AA.
          </p>
          <ul class="result-list">
            <li>Cypress-framework opgezet voor geautomatiseerde functionele en toegankelijkheidstesten</li>
            <li>Volledige WCAG 2.1 AA-testcyclus opgezet met axe, Lighthouse, NVDA en VoiceOver</li>
            <li>Teams begeleid in het structureel borgen van toegankelijkheid</li>
          </ul>
        </article>

        <article class="timeline-item">
          <div class="timeline-meta">
            <span class="timeline-sector">EdTech</span>
            <span class="timeline-period">2020 – 2021</span>
          </div>
          <h3>Evident / NCOI — Test Automation Engineer</h3>
          <p>
            Migratie van verouderde testsuites naar Cypress bij twee scrumteams die
            websites en leerplatforms ontwikkelen voor de NCOI Groep.
          </p>
          <ul class="result-list">
            <li>Per team een volledig Cypress-framework opgezet op basis van Page Object Model</li>
            <li>Ghost Inspector-testsuites volledig gemigreerd en testdekking uitgebreid</li>
            <li>Visuele regressietesten met Percy, e-mailvalidatie via Mailtrap</li>
          </ul>
        </article>

        <article class="timeline-item">
          <div class="timeline-meta">
            <span class="timeline-sector">E-commerce / B2B</span>
            <span class="timeline-period">2019 – 2020</span>
          </div>
          <h3>Sybrand's Place / De Stiho Groep — Agile Tester</h3>
          <p>
            Enige tester in het scrumteam, verantwoordelijk voor het volledige testproces
            van twee B2B-webshops op het Intershop-platform.
          </p>
          <ul class="result-list">
            <li>Fragiel Selenium-framework vervangen door Cypress na gedegen evaluatie</li>
            <li>Data-testid attributen geïmplementeerd samen met ontwikkelaars voor robuuste selectors</li>
            <li>Visuele regressietesten met Applitools, CI/CD-integratie via Jenkins</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- Tools -->
  <section id="tools" class="section">
    <div class="container">
      <h2 class="section-title">Technologieën & tools</h2>
      <div class="tools-grid">
        <div class="tool-group">
          <h4>Web applicaties testen</h4>
          <div class="tag-list">
            <span>Cypress</span>
            <span>Playwright</span>
            <span>TestCafe</span>
            <span>JavaScript</span>
            <span>TypeScript</span>
          </div>
        </div>
        <div class="tool-group">
          <h4>Back-end & API</h4>
          <div class="tag-list">
            <span>Parasoft</span>
            <span>Postman</span>
            <span>SOAP UI</span>
            <span>REST</span>
            <span>SOAP</span>
            <span>SQL</span>
          </div>
        </div>
        <div class="tool-group">
          <h4>Testmanagement</h4>
          <div class="tag-list">
            <span>Jira / Xray</span>
            <span>TestRail</span>
            <span>QMetry</span>
            <span>RTM</span>
            <span>TMap</span>
          </div>
        </div>
        <div class="tool-group">
          <h4>CI/CD & Cloud</h4>
          <div class="tag-list">
            <span>Azure DevOps</span>
            <span>GitLab</span>
            <span>Jenkins</span>
            <span>GitHub Actions</span>
            <span>Docker</span>
          </div>
        </div>
        <div class="tool-group">
          <h4>Toegankelijkheid</h4>
          <div class="tag-list">
            <span>axe</span>
            <span>Lighthouse</span>
            <span>WAVE</span>
            <span>NVDA</span>
            <span>VoiceOver</span>
            <span>WCAG 2.1 AA</span>
          </div>
        </div>
        <div class="tool-group">
          <h4>Sectoren</h4>
          <div class="tag-list tag-list-sectors">
            <span>Overheid</span>
            <span>Zorg</span>
            <span>Energie</span>
            <span>Onderwijs / EdTech</span>
            <span>E-commerce / B2B</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Over mij -->
  <section id="over-mij" class="section section-alt">
    <div class="container">
      <h2 class="section-title">Over mij</h2>
      <div class="about-content">
        <p>
          Ik ben Marc Halewyn, freelance Test Engineer en Testcoördinator, werkzaam vanuit
          Vleuten. Mijn carrière begon in de werktuigbouw, waar ik mijn oog voor detail en
          kwaliteitsbewustzijn ontwikkelde. In 2017 maakte ik de overstap naar het testvak,
          en dat bleek een schot in de roos.
        </p>
        <p>
          Wat mij drijft is kwaliteit. Ik wil dat software werkt zoals bedoeld, dat risico's zichtbaar zijn vóórdat ze
          problemen worden, en dat teams zelfstandig kunnen bouwen aan kwaliteit. Dat bereik
          ik door zelf mee te doen: frameworks opzetten, testplannen schrijven, meedenken in
          sprints, en kennis overdragen.
        </p>
        <p>
          Ik werk het liefst in sectoren met maatschappelijke impact: overheid, zorg, energie —
          waar de kwaliteit van software er echt toe doet. Complexe technische omgevingen met
          API-integraties en meerdere systemen spreken mij aan.
        </p>
        <div class="about-details">
          <div class="detail">
            <strong>Certificeringen</strong>
            <span>TMap Suite · PSM I</span>
          </div>
          <div class="detail">
            <strong>Opleiding</strong>
            <span>HBO Werktuigbouwkunde</span>
          </div>
          <div class="detail">
            <strong>Bedrijf</strong>
            <span>Agile Halewyn — ZZP / freelance</span>
          </div>
          <div class="detail">
            <strong>Regio</strong>
            <span>Utrecht / Randstad (hybride)</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="section section-dark">
    <div class="container">
      <h2 class="section-title section-title-light">Contact</h2>
      <p class="section-intro section-intro-light">
        Op zoek naar een testprofessional die zowel het proces als de techniek beheerst?
        Ik sta open voor nieuwe opdrachten.
      </p>
      <div class="contact-grid">
        <a href="mailto:agileHalewyn@outlook.com" class="contact-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          <span>agileHalewyn@outlook.com</span>
        </a>
        <a href="tel:+31681709941" class="contact-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <span>06 8170 9941</span>
        </a>
        <a href="https://linkedin.com/in/marchalewyn" target="_blank" rel="noopener" class="contact-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
          <span>LinkedIn</span>
        </a>
        <a href={cvPdfHref} target="_blank" rel="noopener" class="contact-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg>
          <span>CV (PDF)</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <p>&copy; 2026 Agile Halewyn — KvK 90024559</p>
    </div>
  </footer>

  <script>
    // Mobile nav toggle
    const toggle = document.querySelector('.nav-toggle');
    const links = document.querySelector('.nav-links');
    if (toggle && links) {
      toggle.addEventListener('click', () => {
        const isOpen = links.classList.toggle('nav-links-open');
        toggle.classList.toggle('nav-toggle-open');
        toggle.setAttribute('aria-expanded', String(isOpen));
      });
      links.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          links.classList.remove('nav-links-open');
          toggle.classList.remove('nav-toggle-open');
          toggle.setAttribute('aria-expanded', 'false');
        });
      });
    }
  </script>
</Base>

<style>
  /* ───── NAV ───── */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-border);
  }
  .nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-md);
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .nav-logo {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-weight: 600;
    color: var(--color-heading);
    text-decoration: none;
  }
  .nav-logo-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: var(--color-accent);
    color: white;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.5px;
  }
  .nav-logo-text {
    font-size: 15px;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }
  .nav-links a {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-light);
    transition: color 0.2s;
  }
  .nav-links a:hover {
    color: var(--color-heading);
  }
  .nav-cta {
    background: var(--color-accent);
    color: white !important;
    padding: 8px 16px;
    border-radius: 6px;
  }
  .nav-cta:hover {
    background: var(--color-accent-light);
    color: white !important;
  }
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .nav-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-heading);
    transition: all 0.3s;
  }
  .nav-toggle-open span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
  .nav-toggle-open span:nth-child(2) { opacity: 0; }
  .nav-toggle-open span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

  @media (max-width: 768px) {
    .nav-toggle { display: flex; }
    .nav-links {
      display: none;
      position: absolute;
      top: 64px;
      left: 0;
      right: 0;
      flex-direction: column;
      background: white;
      padding: var(--space-md);
      border-bottom: 1px solid var(--color-border);
      gap: var(--space-sm);
    }
    .nav-links-open { display: flex; }
    .nav-cta { text-align: center; }
  }

  /* ───── HERO ───── */
  .hero {
    padding: calc(64px + var(--space-2xl)) var(--space-md) var(--space-2xl);
    background: linear-gradient(135deg, #f7fafc 0%, #ebf4ff 100%);
  }
  .hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }
  .hero-content {
    max-width: 640px;
  }
  .hero-label {
    display: inline-block;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
    background: var(--color-tag-bg);
    padding: 4px 12px;
    border-radius: 4px;
  }
  .hero h1 {
    font-size: clamp(2.25rem, 5vw, 3.25rem);
    font-weight: 700;
    margin-bottom: var(--space-xs);
  }
  .hero-title {
    font-size: clamp(1.15rem, 2.5vw, 1.4rem);
    font-weight: 500;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }
  .hero-sub {
    font-size: 1.1rem;
    color: var(--color-text-light);
    margin-bottom: var(--space-lg);
    max-width: 520px;
  }
  .hero-actions {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .hero-cv-note {
    margin-top: var(--space-sm);
    font-size: 15px;
  }
  .hero-cv-note a {
    color: var(--color-accent);
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .hero-cv-note a:hover {
    color: var(--color-accent-light);
  }

  /* ───── BUTTONS ───── */
  .btn {
    display: inline-block;
    padding: 12px 24px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.2s;
  }
  .btn-primary {
    background: var(--color-accent);
    color: white;
  }
  .btn-primary:hover {
    background: var(--color-accent-light);
    color: white;
  }
  .btn-outline {
    border: 2px solid var(--color-border);
    color: var(--color-text);
    background: white;
  }
  .btn-outline:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* ───── SECTIONS ───── */
  .section {
    padding: var(--space-2xl) var(--space-md);
  }
  .section-alt {
    background: var(--color-bg-alt);
  }
  .section-dark {
    background: var(--color-bg-dark);
  }
  .container {
    max-width: var(--max-width);
    margin: 0 auto;
  }
  .section-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    margin-bottom: var(--space-sm);
  }
  .section-title-light {
    color: white;
  }
  .section-intro {
    font-size: 1.05rem;
    color: var(--color-text-light);
    max-width: 600px;
    margin-bottom: var(--space-xl);
  }
  .section-intro-light {
    color: var(--color-text-on-dark);
  }

  /* ───── TWO COLUMNS (Wat ik doe) ───── */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
  }
  @media (max-width: 640px) {
    .two-col { grid-template-columns: 1fr; }
  }
  .card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: var(--space-lg);
  }
  .card-icon {
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }
  .card h3 {
    font-size: 1.2rem;
    margin-bottom: var(--space-sm);
  }
  .card p {
    color: var(--color-text-light);
    font-size: 0.95rem;
    margin-bottom: var(--space-md);
  }
  .card-tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .card-tags li {
    font-size: 12px;
    font-weight: 500;
    padding: 4px 10px;
    background: var(--color-tag-bg);
    color: var(--color-tag-text);
    border-radius: 4px;
  }

  /* ───── TIMELINE (Opdrachten) ───── */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }
